<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_agenda_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_agenda_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_agenda_title"
        android:textColor="#090909"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_agenda_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_agenda_count_placeholder"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_agenda_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/widget_agenda_name_placeholder"
        android:textColor="#090909"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_agenda_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_agenda_meta_placeholder"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_agenda_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="@string/widget_agenda_category_placeholder"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

</LinearLayout>
