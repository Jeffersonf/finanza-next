<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_accent"
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_marginBottom="14dp"
        android:background="#35C96F"
        android:text="@string/widget_empty" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_you"
        android:textColor="#090909"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_amount_placeholder"
        android:textColor="#090909"
        android:textSize="28sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="14dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_spent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/widget_spent_placeholder"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_budget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_budget_placeholder"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_due"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/widget_due_placeholder"
        android:textColor="#6B7280"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
