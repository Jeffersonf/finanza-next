<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_quick_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_quick_mark"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/widget_quick_mark_bg"
        android:gravity="center"
        android:text="@string/widget_quick_mark"
        android:textColor="#08110B"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_quick_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="@string/widget_quick_title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_quick_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:text="@string/widget_quick_subtitle"
            android:textColor="#B8C1CC"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_quick_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:text="@string/widget_quick_account"
            android:textColor="#EFF5FF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_quick_button"
        android:layout_width="72dp"
        android:layout_height="42dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_quick_button_bg"
        android:gravity="center"
        android:text="@string/widget_quick_open"
        android:textColor="#08110B"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
